# Multi-Agent Shared Memory System - Environment Configuration
# Copy this file to .env and fill in the values

# ============== Hugging Face / Model Access ==============
# Hugging Face token for downloading models (optional but recommended)
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Default model to use for agent reasoning
# Can be overridden via command line arguments
DEFAULT_MAIN_MODEL=Qwen/Qwen2.5-7B-Instruct
DEFAULT_NOISE_MODEL=Qwen/Qwen2.5-3B-Instruct

# ============== Model Loading Options ==============
# Use 4-bit quantization to reduce memory usage (true/false)
# 4-bit mode uses significantly less GPU memory but may be slightly slower
USE_4BIT_QUANTIZATION=false

# Use CPU-only mode if no GPU available (true/false)
# Set to true for machines without CUDA GPU
CPU_ONLY=false

# ============== Data Paths ==============
# Directory for benchmark data files
DATA_DIR=data

# Directory for reports and evaluation results
REPORTS_DIR=reports

# Temporary directory for intermediate files
TEMP_DIR=tmp

# ============== Evaluation Settings ==============
# Enable retrieval evaluation by default (true/false)
# Setting to true adds retrieval recall metrics but increases evaluation time
ENABLE_RETRIEVAL_METRICS=true

# Number of scenarios to sample for quick testing (0 = use all)
QUICK_TEST_MODE_SCENARIOS=0

# ============== Logging ==============
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Save detailed logs for each scenario (true/false)
SAVE_DETAILED_LOGS=true

# ============== API Keys (optional) ==============
# If using external APIs for model inference
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
